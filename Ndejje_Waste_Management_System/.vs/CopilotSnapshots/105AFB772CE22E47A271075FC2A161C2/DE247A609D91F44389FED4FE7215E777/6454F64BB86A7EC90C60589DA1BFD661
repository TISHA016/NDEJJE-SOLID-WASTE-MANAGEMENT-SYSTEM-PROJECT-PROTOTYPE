using Ndejje_Waste_Management_System.Data_Model;
using System;
using System.Collections.Generic;
using System.Windows.Forms;

namespace SSWMS_Prototype
{
    public partial class Form1 : Form
    {
        [cite_start]// Simple in-memory storage 
        List<Resident> residents = new List<Resident>();
        List<CollectionSchedule> schedules = new List<CollectionSchedule>();

        public Form1()
        {
            InitializeComponent();
            SetupSampleData();
        }

        private void SetupSampleData()
        {
            [cite_start]// Initial data for demonstration [cite: 19]
            residents.Add(new Resident { FullName = "John Doe", PhoneNumber = "0700111222", Zone = "Ndejje A" });
            dgvResidents.DataSource = null;
            dgvResidents.DataSource = residents;
        }

        [cite_start]// --- WORKFLOW 1: User Login & Roles [cite: 16, 21] ---
        private void btnLogin_Click(object sender, EventArgs e)
        {
            if (txtUsername.Text == "admin" && txtPassword.Text == "1234")
            {
                lblStatus.Text = "Role: Administrator (Full Access)";
                tabControl1.SelectedTab = tabRegister; // Navigate to key function [cite: 10]
            }
            else
            {
                MessageBox.Show("Invalid login credentials.");
            }
        }

        [cite_start]// --- WORKFLOW 2: Register Resident [cite: 17] ---
        private void btnSaveResident_Click(object sender, EventArgs e)
        {
            if (string.IsNullOrEmpty(txtResName.Text)) return;

            var newRes = new Resident
            {
                FullName = txtResName.Text,
                PhoneNumber = txtResPhone.Text,
                Zone = cmbResZone.Text
            };

            residents.Add(newRes);
            dgvResidents.DataSource = null; // Refresh list [cite: 19]
            dgvResidents.DataSource = residents;

            MessageBox.Show("Resident Registered Successfully!");
        }

        [cite_start]// --- WORKFLOW 3: Scheduling & Alerts [cite: 17, 20] ---
        private void btnCreateSchedule_Click(object sender, EventArgs e)
        {
            var sched = new CollectionSchedule
            {
                Zone = cmbSchedZone.Text,
                Date = dtpDate.Value.ToShortDateString(),
                CollectorName = txtCollector.Text
            };

            schedules.Add(sched);

            [cite_start]// ALERT: Simulate SMS Notification 
            string message = $"SMS ALERT: Collection scheduled for {sched.Zone} on {sched.Date}.";
            MessageBox.Show(message, "SMS Dispatch System");
        }
    }
}
using System;
using System.Collections.Generic;
using System.Linq;
using System.Windows.Forms;

namespace Ndejje_Waste_Management_System
{
    // --- PART 1: DATA MODELS (The "Brain") ---
    public class Resident
    {
        public string FullName { get; set; }
        public string PhoneNumber { get; set; }
        public string Zone { get; set; }
        public string Role { get; set; } // Resident, Admin, Collector, Health Officer
        public string Password { get; set; }
        public string Language { get; set; } // English or Luganda
    }

    public class CollectionSchedule
    {
        public string Zone { get; set; }
        public string Date { get; set; }
        public string CollectorName { get; set; }
    }

    public class SignInRecord
    {
        public string ResidentName { get; set; }
        public string Zone { get; set; }
        public string DateTime { get; set; }
    }

    // --- PART 2: MAIN FORM LOGIC (The "Engine") ---
    public partial class Form1 : Form
    {
        List<Resident> residents = new List<Resident>();
        List<CollectionSchedule> schedules = new List<CollectionSchedule>();
        List<SignInRecord> signIns = new List<SignInRecord>();
        Resident currentUser = null;

        public Form1()
        {
            InitializeComponent();
            SetupSystem();
        }

        private void SetupSystem()
        {
            // Rapid Data Initialization
            var zones = new[] { "Zone A", "Zone B", "Zone C", "Zone D" };
            cmbResZone.Items.AddRange(zones);
            cmbSchedZone.Items.AddRange(zones);
            cmbAdminZone.Items.AddRange(zones);

            cmbRole.Items.AddRange(new[] { "Resident", "Admin", "Collector", "Health Officer" });
            cmbLanguage.Items.AddRange(new[] { "English", "Luganda" });

            // Add Default Admin for immediate testing
            residents.Add(new Resident { FullName = "Admin", Role = "Admin", Password = "1234", Zone = "Zone A", Language = "English" });

            // Set Initial UI State
            ConfigureNavigation("Initial");
        }

        // --- FAST NAVIGATION LOGIC ---
        private void ConfigureNavigation(string state)
        {
            switch (state)
            {
                case "Initial":
                    tabRegister.Enabled = true;
                    tabLogin.Enabled = true;
                    tabDashboard.Enabled = false; // Locked
                    tabResident.Enabled = false;  // Locked
                    tabControl1.SelectedTab = tabRegister;
                    break;

                case "LoggedIn":
                    tabRegister.Enabled = false;
                    tabLogin.Enabled = false;
                    tabDashboard.Enabled = true;
                    tabResident.Enabled = true;
                    break;
            }
        }

        // --- WORKFLOW: REGISTRATION ---
        private void btnSaveResident_Click(object sender, EventArgs e)
        {
            if (string.IsNullOrWhiteSpace(txtResName.Text) || string.IsNullOrWhiteSpace(txtAccountPassword.Text))
            {
                MessageBox.Show("Error: Name and Password are required.");
                return;
            }

            residents.Add(new Resident
            {
                FullName = txtResName.Text,
                PhoneNumber = txtResPhone.Text,
                Zone = cmbResZone.Text,
                Role = cmbRole.Text,
                Password = txtAccountPassword.Text,
                Language = cmbLanguage.Text
            });

            MessageBox.Show("Registration Successful! Please Login.");
            tabControl1.SelectedTab = tabLogin;
        }

        // --- WORKFLOW: THE LOGIN "BRIDGE" ---
        private void btnLogin_Click(object sender, EventArgs e)
        {
            string userIn = txtLoginUsername.Text.Trim();
            string passIn = txtLoginPassword.Text;

            // Fast lookup using LINQ
            var user = residents.FirstOrDefault(r =>
                (r.FullName.Equals(userIn, StringComparison.OrdinalIgnoreCase) || r.PhoneNumber == userIn)
                && r.Password == passIn);

            if (user != null)
            {
                currentUser = user;
                ConfigureNavigation("LoggedIn");

                // INSTANT REDIRECTION based on role
                if (user.Role == "Resident")
                {
                    tabControl1.SelectedTab = tabResident;
                    LoadResidentPortal();
                }
                else // Admin, Collector, Health Officer
                {
                    tabControl1.SelectedTab = tabDashboard;
                    RefreshAdminStats();
                }
            }
            else
            {
                MessageBox.Show("Access Denied: Invalid Username or Password.");
            }
        }

        // --- WORKFLOW: RESIDENT PORTAL ---
        private void LoadResidentPortal()
        {
            lblResWelcome.Text = $"Active Session: {currentUser.FullName} ({currentUser.Zone})";

            var schedule = schedules.FirstOrDefault(s => s.Zone == currentUser.Zone);
            bool isLuganda = currentUser.Language == "Luganda";

            if (schedule != null)
            {
                lblResNextSchedule.Text = isLuganda
                    ? $"Okukunganya e Ndejje {schedule.Zone} kuliwo nga {schedule.Date}"
                    : $"Waste collection in {schedule.Zone} is scheduled for {schedule.Date}";
            }
            else
            {
                lblResNextSchedule.Text = isLuganda ? "Tewali nteekateeka ya kazigizigi." : "No upcoming schedule found.";
            }
        }

        private void btnSignIn_Click(object sender, EventArgs e)
        {
            signIns.Add(new SignInRecord
            {
                ResidentName = currentUser.FullName,
                Zone = currentUser.Zone,
                DateTime = DateTime.Now.ToString("g")
            });

            string msg = currentUser.Language == "Luganda"
                ? "Webale okwebala! Omulimu gwa takasasi gutandise."
                : "Sign-in confirmed! Thank you for participating in waste management.";

            MessageBox.Show(msg);
        }

        // --- WORKFLOW: ADMIN / STAFF DASHBOARD ---
        private void btnCreateSchedule_Click(object sender, EventArgs e)
        {
            schedules.Add(new CollectionSchedule
            {
                Zone = cmbSchedZone.Text,
                Date = dtpDate.Value.ToShortDateString(),
                CollectorName = txtCollector.Text
            });
            RefreshAdminStats();
            MessageBox.Show("Schedule Published & Residents Notified.");
        }

        private void RefreshAdminStats()
        {
            lblTotalResidentsValue.Text = residents.Count.ToString();
            lblActiveSchedules.Text = schedules.Count.ToString();
            dgvSignIns.DataSource = null;
            dgvSignIns.DataSource = signIns;
        }

        private void btnLogout_Click(object sender, EventArgs e)
        {
            currentUser = null;
            txtLoginUsername.Clear();
            txtLoginPassword.Clear();
            ConfigureNavigation("Initial");
        }
    }
}
using Ndejje_Waste_Management_System.Data_Model;
using System;
using System.Collections.Generic;
using System.Linq;
using System.Windows.Forms;

namespace Ndejje_Waste_Management_System
{
    public partial class Form1 : Form
    {
        // --- DATA STORAGE ---
        List<Resident> residents = new List<Resident>();
        List<CollectionSchedule> schedules = new List<CollectionSchedule>();
        List<CollectionRecord> collectionRecords = new List<CollectionRecord>();
        List<SignInRecord> signIns = new List<SignInRecord>();
        Resident currentUser = null;

        public Form1()
        {
            InitializeComponent();
            PopulateZones();
            SetupSampleData();

            // INITIAL UI STATE: Force user to Register first
            ConfigureNavigation("Initial");
        }

        private void PopulateZones()
        {
            var zones = new string[] { "Zone A", "Zone B", "Zone C", "Zone D" };
            cmbResZone.Items.AddRange(zones);
            cmbSchedZone.Items.AddRange(zones);
            if (cmbAdminZone != null)
            {
                cmbAdminZone.Items.Clear();
                cmbAdminZone.Items.AddRange(zones);
                cmbAdminZone.SelectedIndex = 0;
            }

            if (cmbRole != null)
            {
                cmbRole.Items.AddRange(new string[] { "Resident", "Admin", "Collector", "Health Officer" });
                cmbRole.SelectedIndex = 0;
            }

            if (cmbLanguage != null)
            {
                cmbLanguage.Items.AddRange(new string[] { "English", "Luganda" });
                cmbLanguage.SelectedIndex = 0;
            }
        }

        private void SetupSampleData()
        {
            residents.Add(new Resident { FullName = "Admin", Role = "Admin", Password = "1234", Zone = "Zone A" });
            schedules.Add(new CollectionSchedule { Zone = "Zone A", Date = DateTime.Now.AddDays(2).ToShortDateString(), CollectorName = "Samuel" });
            RefreshDashboard();
        }

        // --- NAVIGATION CONTROL ---
        private void ConfigureNavigation(string state)
        {
            switch (state)
            {
                case "Initial":
                    tabControl1.SelectedTab = tabRegister; // Start here
                    tabDashboard.Enabled = false;
                    tabResident.Enabled = false;
                    lblStatus.Text = "Please register to create an account.";
                    // hide login panel/button until user moves to login
                    if (pnlLoginArea != null) pnlLoginArea.Visible = false;
                    if (btnLogin != null) { btnLogin.Visible = false; btnLogin.Enabled = false; }
                    break;
                case "PostRegistration":
                    tabControl1.SelectedTab = tabLogin;
                    lblStatus.Text = "Registration successful. Please login.";
                    // show and activate login controls
                    if (pnlLoginArea != null) pnlLoginArea.Visible = true;
                    if (btnLogin != null) { btnLogin.Visible = true; btnLogin.Enabled = true; }
                    if (txtLoginUsername != null) txtLoginUsername.Focus();
                    break;
                case "LoggedIn":
                    // Access is handled in ApplyAccessForCurrentUser()
                    break;
            }
        }

        // --- WORKFLOW 1: REGISTRATION ---
        private void btnSaveResident_Click(object sender, EventArgs e)
        {
            if (string.IsNullOrWhiteSpace(txtResName.Text) || string.IsNullOrWhiteSpace(txtAccountPassword.Text))
            {
                MessageBox.Show("Please enter a name and password.");
                return;
            }

            var newRes = new Resident
            {
                FullName = txtResName.Text,
                PhoneNumber = txtResPhone.Text,
                Zone = cmbResZone.Text,
                Role = cmbRole?.Text ?? "Resident",
                Password = txtAccountPassword.Text,
                Language = cmbLanguage?.Text ?? "English"
            };

            residents.Add(newRes);
            ConfigureNavigation("PostRegistration");
        }

        // --- WORKFLOW 2: LOGIN ---
        private void btnLogin_Click(object sender, EventArgs e)
        {
            try
            {
                var username = !string.IsNullOrWhiteSpace(txtLoginUsername.Text) ? txtLoginUsername.Text.Trim() : txtUsername.Text?.Trim();
                var password = !string.IsNullOrEmpty(txtLoginPassword.Text) ? txtLoginPassword.Text : txtPassword.Text;

                // Built-in admin fallback
                if (!string.IsNullOrWhiteSpace(username) && string.Equals(username, "admin", StringComparison.OrdinalIgnoreCase) && password == "1234")
                {
                    currentUser = residents.FirstOrDefault(r => string.Equals(r.Role, "Admin", StringComparison.OrdinalIgnoreCase));
                    if (currentUser == null)
                    {
                        currentUser = new Resident { FullName = "Administrator", Role = "Admin", Password = "1234", Zone = "Zone A", Language = "English" };
                        residents.Add(currentUser);
                    }
                    ApplyAccessForCurrentUser();
                    return;
                }

                var user = residents.FirstOrDefault(r =>
                    (!string.IsNullOrWhiteSpace(r.FullName) && r.FullName.Equals(username, StringComparison.OrdinalIgnoreCase)) ||
                    (!string.IsNullOrWhiteSpace(r.PhoneNumber) && r.PhoneNumber.Equals(username, StringComparison.OrdinalIgnoreCase)) && r.Password == password);

                // Try secure match: FullName or Phone AND password
                if (user == null)
                {
                    user = residents.FirstOrDefault(r => ((r.FullName != null && r.FullName.Equals(username, StringComparison.OrdinalIgnoreCase)) || (r.PhoneNumber != null && r.PhoneNumber.Equals(username, StringComparison.OrdinalIgnoreCase))) && r.Password == password);
                }

                if (user != null)
                {
                    currentUser = user;
                    ApplyAccessForCurrentUser();
                }
                else
                {
                    MessageBox.Show("Invalid credentials.");
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Login error: {ex.Message}");
            }
        }

        // --- WORKFLOW 3: ROLE-BASED DASHBOARD REDIRECTION ---
        private void ApplyAccessForCurrentUser()
        {
            string role = currentUser.Role ?? "Resident";
            lblStatus.Text = $"User: {currentUser.FullName} | Role: {role}";
            if (lblStatus != null) lblStatus.Visible = true;

            // 1. Admin/Collector/Health Officer View
            if (string.Equals(role, "Admin", StringComparison.OrdinalIgnoreCase)
                || string.Equals(role, "Collector", StringComparison.OrdinalIgnoreCase)
                || string.Equals(role, "Health Officer", StringComparison.OrdinalIgnoreCase))
            {
                tabDashboard.Enabled = true;
                tabResident.Enabled = true;
                tabControl1.SelectedTab = tabDashboard;
                UpdateResidentGridVisibility(true);
                RefreshDashboard();
            }
            // 2. Resident/Health Officer View
            else
            {
                tabDashboard.Enabled = false;
                tabResident.Enabled = true;
                tabControl1.SelectedTab = tabResident;
                ShowResidentMessages(currentUser);
                UpdateResidentGridVisibility(false);
            }
        }

        private void UpdateResidentGridVisibility(bool visible)
        {
            dgvResidents.Visible = visible;
            dgvResidents.DataSource = visible ? residents.ToList() : null;
        }

        // --- WORKFLOW 4: SCHEDULING & LOCALIZATION ---
        private void btnCreateSchedule_Click(object sender, EventArgs e)
        {
            var sched = new CollectionSchedule
            {
                Zone = cmbSchedZone.Text,
                Date = dtpDate.Value.ToShortDateString(),
                CollectorName = txtCollector.Text
            };
            schedules.Add(sched);

            // Notify relevant residents
            var affected = residents.Where(r => r.Zone == sched.Zone);
            foreach (var res in affected)
            {
                string msg = GetLocalizedText(res.Language, "NextSchedule", sched.Zone, sched.Date);
                MessageBox.Show(msg, $"SMS to {res.FullName}");
            }
            RefreshDashboard();
        }

        private void ShowResidentMessages(Resident r)
        {
            lblResWelcome.Text = $"Welcome, {r.FullName}";
            var next = schedules.FirstOrDefault(s => s.Zone == r.Zone);

            lblResNextScheduleEnglish.Text = next != null
                ? GetLocalizedText("English", "NextSchedule", next.Zone, next.Date)
                : "No schedule found.";

            lblResNextScheduleLuganda.Text = next != null
                ? GetLocalizedText("Luganda", "NextSchedule", next.Zone, next.Date)
                : "Tewali nteekateeka ya kazigizigi.";
        }

        private string GetLocalizedText(string lang, string key, params object[] args)
        {
            bool isLuganda = lang == "Luganda";
            switch (key)
            {
                case "NextSchedule":
                    return isLuganda
                        ? string.Format("Okukunganya takasasi mu {0} kuliwo nga {1}.", args)
                        : string.Format("Waste collection in {0} is scheduled for {1}.", args);
                case "SignInSuccess":
                    return isLuganda
                        ? string.Format("Mwasuze obudde, {0}. Okweyongeza kwetuweereddwa.", args)
                        : string.Format("You have signed in, {0}.", args);
                case "ThankYou":
                    return isLuganda
                        ? "Webale nnyo olw'okuba mukisa!"
                        : "Thank you for being collaborative.";
                default:
                    return "";
            }
        }

        // Resident Sign-in handler
        private void btnSignIn_Click(object sender, EventArgs e)
        {
            if (currentUser == null)
            {
                MessageBox.Show("Please login first to sign in.");
                ConfigureNavigation("PostRegistration");
                return;
            }

            var sign = new SignInRecord
            {
                ResidentName = currentUser.FullName,
                Zone = currentUser.Zone,
                DateTime = System.DateTime.Now.ToString()
            };
            signIns.Add(sign);

            // update sign-in grid
            if (dgvSignIns != null)
            {
                dgvSignIns.DataSource = null;
                dgvSignIns.DataSource = signIns.ToList();
            }

            // localized feedback
            var msg = GetLocalizedText(currentUser.Language ?? "English", "SignInSuccess", currentUser.FullName);
            var thanks = GetLocalizedText(currentUser.Language ?? "English", "ThankYou");
            MessageBox.Show($"{msg}\n{thanks}");
        }

        // Admin: View residents and sign-ins assigned to selected zone
        private void btnViewAssigned_Click(object sender, EventArgs e)
        {
            var zone = cmbAdminZone?.Text;
            if (string.IsNullOrWhiteSpace(zone))
            {
                MessageBox.Show("Please select a zone.");
                return;
            }

            // show residents in dgvResidents
            var assigned = residents.Where(r => string.Equals(r.Zone, zone, StringComparison.OrdinalIgnoreCase)).ToList();
            if (dgvResidents != null)
            {
                dgvResidents.DataSource = null;
                dgvResidents.DataSource = assigned;
                dgvResidents.Visible = true;
            }

            // show sign-ins for the zone
            var signinsForZone = signIns.Where(s => string.Equals(s.Zone, zone, StringComparison.OrdinalIgnoreCase)).ToList();
            if (dgvSignIns != null)
            {
                dgvSignIns.DataSource = null;
                dgvSignIns.DataSource = signinsForZone;
            }
        }

        private void RefreshDashboard()
        {
            lblTotalResidentsValue.Text = residents.Count.ToString();
            lblTotalCollectorsValue.Text = residents.Count(r => r.Role == "Collector").ToString();
            lblUpcomingSchedulesValue.Text = schedules.Count.ToString();

            if (dgvRecentCollections != null)
                dgvRecentCollections.DataSource = collectionRecords.OrderByDescending(c => c.Date).Take(5).ToList();
        }

        private void btnLogout_Click(object sender, EventArgs e)
        {
            currentUser = null;
            ConfigureNavigation("Initial");
            txtLoginUsername.Clear();
            txtLoginPassword.Clear();
        }

        // Navigate from Register tab to Login tab
        private void btnTabLogin_Click(object sender, EventArgs e)
        {
            if (tabControl1 != null && tabLogin != null)
                tabControl1.SelectedTab = tabLogin;

            // Ensure login controls are visible and active when the user switches to Login
            if (pnlLoginArea != null) pnlLoginArea.Visible = true;
            if (btnLogin != null) { btnLogin.Visible = true; btnLogin.Enabled = true; }
            if (txtLoginUsername != null) txtLoginUsername.Focus();
        }

        // New: Go to Login button on Register panel
        private void btnLoginNow_Click(object sender, EventArgs e)
        {
            // Switch to Login tab and activate login controls
            if (tabControl1 != null && tabLogin != null)
                tabControl1.SelectedTab = tabLogin;

            if (pnlLoginArea != null) pnlLoginArea.Visible = true;
            if (btnLogin != null) { btnLogin.Visible = true; btnLogin.Enabled = true; }

            // If credentials already provided in login panel, attempt login immediately
            if (!string.IsNullOrWhiteSpace(txtLoginUsername?.Text) && !string.IsNullOrEmpty(txtLoginPassword?.Text))
            {
                btnLogin_Click(btnLogin, EventArgs.Empty);
            }
            else
            {
                txtLoginUsername?.Focus();
            }
        }
    }
}

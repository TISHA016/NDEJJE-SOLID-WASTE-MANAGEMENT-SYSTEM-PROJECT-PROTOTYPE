using Ndejje_Waste_Management_System.Data_Model;
using System;
using System.Collections.Generic;
using System.Linq;
using System.Windows.Forms;

namespace Ndejje_Waste_Management_System
{
    public partial class Form1 : Form
    {
        // Simple in-memory storage
        List<Resident> residents = new List<Resident>();
        List<CollectionSchedule> schedules = new List<CollectionSchedule>();
        List<CollectionRecord> collectionRecords = new List<CollectionRecord>();

        public Form1()
        {
            InitializeComponent();
            PopulateZones();
            SetupSampleData();
        }

        private void PopulateZones()
        {
            var zones = new string[] { "Zone A", "Zone B", "Zone C", "Zone D" };

            // Ensure combo boxes are available and populate them
            cmbResZone.Items.Clear();
            cmbResZone.Items.AddRange(zones);
            if (cmbResZone.Items.Count > 0) cmbResZone.SelectedIndex = 0;

            cmbSchedZone.Items.Clear();
            cmbSchedZone.Items.AddRange(zones);
            if (cmbSchedZone.Items.Count > 0) cmbSchedZone.SelectedIndex = 0;

            // role options for account creation
            if (cmbRole != null)
            {
                cmbRole.Items.Clear();
                cmbRole.Items.AddRange(new string[] { "Resident", "Admin", "Collector" });
                cmbRole.SelectedIndex = 0;
            }
        }

        private void SetupSampleData()
        {
            // Initial data for demonstration
            residents.Add(new Resident { FullName = "John Doe", PhoneNumber = "0700111222", Zone = "Zone A", Role = "Resident", Password = "pass123" });
            residents.Add(new Resident { FullName = "Jane Smith", PhoneNumber = "0700222333", Zone = "Zone B", Role = "Collector", Password = "collect@1" });

            // Sample schedule
            schedules.Add(new CollectionSchedule { Zone = "Zone A", Date = DateTime.Now.AddDays(2).ToShortDateString(), CollectorName = "Samuel" });

            // Sample collection records
            collectionRecords.Add(new CollectionRecord { ResidentName = "John Doe", CollectorName = "Samuel", Date = DateTime.Now.AddDays(-1).ToShortDateString(), Zone = "Zone A" });
            collectionRecords.Add(new CollectionRecord { ResidentName = "Jane Smith", CollectorName = "Marta", Date = DateTime.Now.AddDays(-3).ToShortDateString(), Zone = "Zone B" });

            dgvResidents.DataSource = null;
            dgvResidents.DataSource = residents;

            RefreshDashboard();
        }

        // --- WORKFLOW 1: User Login & Roles ---
        private void btnLogin_Click(object sender, EventArgs e)
        {
            if (txtUsername.Text == "admin" && txtPassword.Text == "1234")
            {
                lblStatus.Text = "Role: Administrator (Full Access)";
                // Navigate to the Dashboard tab after successful login
                tabControl1.SelectedTab = tabDashboard;
                RefreshDashboard();
            }
            else
            {
                MessageBox.Show("Invalid login credentials.");
            }
        }

        // --- WORKFLOW 2: Register Resident ---
        private void btnSaveResident_Click(object sender, EventArgs e)
        {
            if (string.IsNullOrEmpty(txtResName.Text)) return;

            var newRes = new Resident
            {
                FullName = txtResName.Text,
                PhoneNumber = txtResPhone.Text,
                Zone = cmbResZone.Text,
                Role = cmbRole != null ? cmbRole.Text : "Resident",
                Password = txtAccountPassword != null ? txtAccountPassword.Text : string.Empty
            };

            residents.Add(newRes);
            dgvResidents.DataSource = null; // Refresh list
            dgvResidents.DataSource = residents;

            MessageBox.Show("Resident Registered Successfully!");

            RefreshDashboard();
        }

        // --- WORKFLOW 3: Scheduling & Alerts ---
        private void btnCreateSchedule_Click(object sender, EventArgs e)
        {
            var sched = new CollectionSchedule
            {
                Zone = cmbSchedZone.Text,
                Date = dtpDate.Value.ToShortDateString(),
                CollectorName = txtCollector.Text
            };

            schedules.Add(sched);

            // ALERT: Simulate SMS Notification
            string message = $"SMS ALERT: Collection scheduled for {sched.Zone} on {sched.Date}.";
            MessageBox.Show(message, "SMS Dispatch System");

            RefreshDashboard();
        }

        private void RefreshDashboard()
        {
            // Totals
            lblTotalResidentsValue.Text = residents.Count.ToString();
            lblTotalCollectorsValue.Text = schedules.Select(s => s.CollectorName).Where(n => !string.IsNullOrEmpty(n)).Distinct().Count().ToString();
            lblUpcomingSchedulesValue.Text = schedules.Count.ToString();
            lblTotalCollectionsValue.Text = collectionRecords.Count.ToString();

            // Recent collections (show last 5)
            if (dgvRecentCollections != null)
            {
                var recent = collectionRecords.OrderByDescending(c => DateTime.TryParse(c.Date, out var d) ? d : DateTime.MinValue).Take(5).ToList();
                dgvRecentCollections.DataSource = null;
                dgvRecentCollections.DataSource = recent;
            }

            // System info
            lblSystemInfo.Text = $"System: {Environment.MachineName} | OS: {Environment.OSVersion} | AppVersion: {Application.ProductVersion}";
        }
    }
}
